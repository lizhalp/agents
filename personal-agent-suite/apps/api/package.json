{
  "name": "@agent-suite/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --config ../../vitest.config.ts --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --config ../../vitest.config.ts src/*.integration.test.ts"
  },
  "dependencies": {
    "@agent-suite/config": "workspace:*",
    "@agent-suite/shared-types": "workspace:*",
    "@aws-sdk/client-s3": "^3.830.0",
    "@temporalio/client": "^1.11.4",
    "fastify": "^5.3.3",
    "ioredis": "^5.6.1",
    "pg": "^8.16.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.2",
    "tsx": "^4.19.4"
  }
}
