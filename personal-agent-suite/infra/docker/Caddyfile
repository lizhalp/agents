{$AUTHENTIK_HOST} {
  encode gzip zstd

  handle {
    reverse_proxy authentik-server:9000
  }
}

{$PUBLIC_BASE_URL} {
  encode gzip zstd

  @admin path /grafana* /temporal*
  basic_auth @admin {
    {$ADMIN_USER} {$ADMIN_PASSWORD_HASH}
  }

  handle /api/auth/* {
    reverse_proxy web:3000
  }

  handle /api/local-login {
    reverse_proxy web:3000
  }

  handle /api/register {
    reverse_proxy web:3000
  }

  handle /api/* {
    reverse_proxy api:4000
  }

  handle /health/* {
    reverse_proxy api:4000
  }

  handle /authentik/* {
    uri strip_prefix /authentik
    reverse_proxy authentik-server:9000
  }

  handle /grafana* {
    uri strip_prefix /grafana
    reverse_proxy grafana:3000
  }

  handle /temporal* {
    uri strip_prefix /temporal
    reverse_proxy temporal-ui:8080
  }

  handle {
    reverse_proxy web:3000
  }
}
